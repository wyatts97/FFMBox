{
  "name": "ffmbox",
  "version": "1.0.0",
  "packageManager": "pnpm@10.12.4",
  "private": true,
  "description": "FFMBox - A full-stack media conversion tool with FFmpeg",
  
  "scripts": {
    "start": "pnpm --filter=ffmbox-server start",
    "dev": "concurrently \"pnpm --filter=ffmbox-server dev\" \"pnpm --filter=ffmbox-client dev\"",
    "build": "pnpm --filter=ffmbox-client build && pnpm --filter=ffmbox-server build",
    "lint": "pnpm --filter=./app/* lint",
    "test": "pnpm --filter=./app/* test",
    "clean": "rimraf node_modules pnpm-lock.yaml app/*/dist app/*/build public"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "keywords": [
    "ffmpeg",
    "media",
    "conversion",
    "video",
    "audio",
    "react",
    "express",
    "websockets"
  ],
  "author": "",
  "license": "MIT"
}
