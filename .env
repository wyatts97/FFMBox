# Application Ports
PORT=6900
FRONTEND_PORT=80

# Environment
NODE_ENV=production

# File Operations
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/output
MAX_FILE_SIZE=524288000
FILE_UPLOAD_TIMEOUT=300s

# FFmpeg Configuration
FFMPEG_THREADS=2
FFMPEG_PRESET=medium

# Security
JWT_SECRET=your_secure_random_string_here
API_RATE_LIMIT=100req/min

# CORS
CORS_ORIGIN=

